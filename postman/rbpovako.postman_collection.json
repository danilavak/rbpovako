    "type": "noauth"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{adminUsername}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/login",
            "auth": {
              "type": "noauth"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Admin login works\", function () { pm.response.to.have.status(200); });",
                  "var body = pm.response.json();",
                  "pm.environment.set(\"adminAccessToken\", body.accessToken);",
                  "pm.environment.set(\"adminRefreshToken\", body.refreshToken);",
                  "pm.test(\"Admin tokens saved\", function () {",
                  "  pm.expect(pm.environment.get(\"adminAccessToken\")).to.not.be.empty;",
                  "  pm.expect(pm.environment.get(\"adminRefreshToken\")).to.not.be.empty;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Current admin user",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{adminAccessToken}}",
                  "type": "string"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Bearer token works\", function () { pm.response.to.have.status(200); });",
                  "pm.test(\"Current user is admin\", function () { pm.expect(pm.response.json().username).to.eql(pm.environment.get(\"adminUsername\")); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Register candidate",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{candidateUsername}}\",\n  \"email\": \"{{candidateEmail}}\",\n  \"password\": \"{{candidatePassword}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/register",
            "auth": {
              "type": "noauth"
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var runId = pm.environment.get(\"runId\");",
                  "if (!runId) {",
                  "  runId = String(Date.now());",
                  "  pm.environment.set(\"runId\", runId);",
                  "}",
                  "pm.environment.set(\"candidateUsername\", \"candidate_\" + runId);",
                  "pm.environment.set(\"candidateEmail\", \"candidate_\" + runId + \"@example.com\");"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Candidate registration works\", function () { pm.response.to.have.status(200); });",
                  "pm.test(\"Registered user has candidate role\", function () { pm.expect(pm.response.json().role).to.eql(\"CANDIDATE\"); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Login candidate",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{candidateUsername}}\",\n  \"password\": \"{{candidatePassword}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/login",
            "auth": {
              "type": "noauth"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Candidate login works\", function () { pm.response.to.have.status(200); });",
                  "var body = pm.response.json();",
                  "pm.environment.set(\"candidateAccessToken\", body.accessToken);",
                  "pm.environment.set(\"candidateRefreshToken\", body.refreshToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh admin token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{adminRefreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/refresh",
            "auth": {
              "type": "noauth"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Refresh works\", function () { pm.response.to.have.status(200); });",
                  "pm.environment.set(\"previousAdminRefreshToken\", pm.environment.get(\"adminRefreshToken\"));",
                  "var body = pm.response.json();",
                  "pm.environment.set(\"adminAccessToken\", body.accessToken);",
                  "pm.environment.set(\"adminRefreshToken\", body.refreshToken);",
                  "pm.test(\"Refresh token rotated\", function () { pm.expect(pm.environment.get(\"previousAdminRefreshToken\")).to.not.eql(pm.environment.get(\"adminRefreshToken\")); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Reuse old refresh token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{previousAdminRefreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/refresh",
            "auth": {
              "type": "noauth"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Old refresh token is rejected\", function () { pm.response.to.have.status(401); });"
                ]
              }
            }
          ]
        }
      ]
    },
