    "item":  [
                 {
                     "name":  "Auth and CSRF",
                     "item":  [
                                  {
                                      "name":  "Get CSRF token",
                                      "request":  {
                                                      "method":  "GET",
                                                      "url":  "{{baseUrl}}/api/csrf"
                                                  },
                                      "event":  [
                                                    {
                                                        "listen":  "test",
                                                        "script":  {
                                                                       "type":  "text/javascript",
                                                                       "exec":  [
                                                                                    "const data = pm.response.json();",
                                                                                    "pm.environment.set(\"csrfToken\", data.token);"
                                                                                ]
                                                                   }
                                                    }
                                                ]
                                  },
                                  {
                                      "name":  "Register candidate",
                                      "request":  {
                                                      "method":  "POST",
                                                      "header":  [
                                                                     {
                                                                         "key":  "Content-Type",
                                                                         "value":  "application/json"
                                                                     },
                                                                     {
                                                                         "key":  "X-XSRF-TOKEN",
                                                                         "value":  "{{csrfToken}}"
                                                                     }
                                                                 ],
                                                      "url":  "{{baseUrl}}/auth/register",
                                                      "body":  {
                                                                   "mode":  "raw",
                                                                   "raw":  "{\n  \"username\": \"candidate_demo\",\n  \"email\": \"candidate.demo@example.com\",\n  \"password\": \"Candidate!234\"\n}"
                                                               }
                                                  }
                                  },
                                  {
                                      "name":  "Current user",
                                      "request":  {
                                                      "method":  "GET",
                                                      "url":  "{{baseUrl}}/auth/me"
                                                  }
                                  }
                              ]
                 },
